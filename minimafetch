set -euo pipefail

c1=$'\033[1;36m'   # logo - cyan
c2=$'\033[1;37m'   # labels - bold white
reset=$'\033[0m'

user="${USER:-$(whoami)}"
host="${HOSTNAME:-$(uname -n)}"

uptime_str=$(awk '{
  d=int($1/86400); h=int(($1%86400)/3600); m=int(($1%3600)/60)
  if (d>0)      printf "%dd %dh %dm", d, h, m
  else if (h>0) printf "%dh %dm", h, m
  else          printf "%dm", m
}' /proc/uptime)

read -r total used <<< "$(df -BG / | awk 'NR==2 { gsub("G",""); print $2, $3 }')"
storage_str="${used}GB / ${total}GB"

