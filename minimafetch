)

info_offset=4

echo
for i in "${!logo[@]}"; do
  info_i=$((i - info_offset))
  text=""
  if (( info_i >= 0 && info_i < ${#info[@]} )); then
    text="${info[$info_i]}"
  fi
  printf "${c1}%-28s${reset} %s\n" "${logo[$i]}" "$text"
done
